#!/usr/bin/env node

const fs = require("fs");
const os = require("os");
const path = require("path");
const readline = require("readline");

process.stdout.on("error", (error) => {
  if (error.code === "EPIPE") {
    process.exit(0);
  }
  throw error;
});

const usage = `Usage: codex-session-recap [--excerpt|-e] [--cwd <path>]

Print Codex session transcript paths whose latest recorded cwd is the current
directory or one of its child directories.

Options:
  -e, --excerpt   Also print first 50 and last 50 lines from each matching file
      --cwd PATH  Use PATH instead of the process current working directory
  -h, --help      Show this help
`;

function parseArgs(argv) {
  const options = {
    cwd: process.cwd(),
    excerpt: false,
  };

  for (let i = 0; i < argv.length; i += 1) {
    const arg = argv[i];
    switch (arg) {
      case "-e":
      case "--excerpt":
        options.excerpt = true;
        break;
      case "--cwd":
        i += 1;
        if (i >= argv.length) {
          throw new Error("--cwd requires a path");
        }
        options.cwd = argv[i];
        break;
      case "-h":
      case "--help":
        process.stdout.write(usage);
        process.exit(0);
        break;
      default:
        throw new Error(`unknown argument: ${arg}`);
    }
  }

  return options;
}

function codexHome() {
  return process.env.CODEX_HOME || path.join(os.homedir(), ".codex");
}

async function* walkFiles(dir) {
  let entries;
  try {
    entries = await fs.promises.readdir(dir, { withFileTypes: true });
  } catch {
    return;
  }
  entries.sort((a, b) => a.name.localeCompare(b.name));

  for (const entry of entries) {
    const fullPath = path.join(dir, entry.name);
    if (entry.isDirectory()) {
      yield* walkFiles(fullPath);
    } else if (entry.isFile() && /^rollout-.*\.jsonl$/.test(entry.name)) {
      yield fullPath;
    }
  }
}

function cwdIsInTree(sessionCwd, root) {
  if (!sessionCwd) {
    return false;
  }

  const relative = path.relative(root, path.resolve(sessionCwd));
  return relative === "" || (!relative.startsWith("..") && !path.isAbsolute(relative));
}

async function latestSessionCwd(file) {
  const stream = fs.createReadStream(file, { encoding: "utf8" });
  const lines = readline.createInterface({
    input: stream,
    crlfDelay: Infinity,
  });

  let latest = null;
  for await (const line of lines) {
    if (!line.trim()) {
      continue;
    }

    let item;
    try {
      item = JSON.parse(line);
    } catch {
      continue;
    }

    if ((item.type === "session_meta" || item.type === "turn_context") && item.payload?.cwd) {
      latest = item.payload.cwd;
    }
  }

  return latest;
}

async function printExcerpt(file) {
  const stream = fs.createReadStream(file, { encoding: "utf8" });
  const lines = readline.createInterface({
    input: stream,
    crlfDelay: Infinity,
  });

  const head = [];
  const tail = [];
  let total = 0;

  for await (const line of lines) {
    total += 1;
    if (head.length < 50) {
      head.push(line);
    }
    tail.push(line);
    if (tail.length > 50) {
      tail.shift();
    }
  }

  process.stdout.write(`----- excerpt: ${file} -----\n`);
  if (total <= 100) {
    const remainingLineCount = total - head.length;
    const remainingLines =
      remainingLineCount > 0 ? tail.slice(tail.length - remainingLineCount) : [];
    for (const line of head.concat(remainingLines)) {
      process.stdout.write(`${line}\n`);
    }
    return;
  }

  for (const line of head) {
    process.stdout.write(`${line}\n`);
  }
  process.stdout.write(`----- omitted ${total - 100} lines -----\n`);
  for (const line of tail) {
    process.stdout.write(`${line}\n`);
  }
}

async function main() {
  const options = parseArgs(process.argv.slice(2));
  const root = path.resolve(options.cwd);
  const sessionsDir = path.join(codexHome(), "sessions");

  if (!fs.existsSync(sessionsDir)) {
    throw new Error(`sessions directory not found: ${sessionsDir}`);
  }

  let found = false;
  for await (const file of walkFiles(sessionsDir)) {
    const sessionCwd = await latestSessionCwd(file);
    if (!cwdIsInTree(sessionCwd, root)) {
      continue;
    }

    found = true;
    process.stdout.write(`${file}\n`);
    if (options.excerpt) {
      await printExcerpt(file);
    }
  }

  process.exitCode = found ? 0 : 1;
}

main().catch((error) => {
  process.stderr.write(`codex-session-recap: ${error.message}\n`);
  process.exit(2);
});
