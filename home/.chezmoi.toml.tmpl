{{- $isWork := promptBoolOnce . "isWork" "Is this a work machine" -}}
{{- $npmTokenOpRef := "" -}}
{{- if $isWork -}}
{{- $npmTokenOpRef = promptStringOnce . "npmTokenOpRef" "1Password secret reference for npm token (blank to skip)" "" -}}
{{- end -}}

[data]
    isWork = {{ $isWork }}
    npmTokenOpRef = {{ $npmTokenOpRef | quote }}

[merge]
command = "bash"
args = [
    "-c",
    'cp "$1" "$2" && code --wait --new-window --merge "$3" "$1" "$2" "$4"',
    "bash",
    "{{ `{{ .Target }}` }}",
    "{{ `{{ .Target }}` }}.base",
    "{{ `{{ .Destination }}` }}",
    "{{ `{{ .Source }}` }}",
]
