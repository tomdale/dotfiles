#!/usr/bin/env zsh
# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║ $ZDOTDIR/.zshenv - Environment Configuration (subshell entry point)      ║
# ╠═══════════════════════════════════════════════════════════════════════════╣
# ║ When ZDOTDIR is inherited from a parent shell (subshells, non-interactive ║
# ║ shells spawned by tools like Claude Code), zsh looks for .zshenv HERE    ║
# ║ instead of in ~/. Without this file, subshells skip env.zsh entirely    ║
# ║ and inherit a stale PATH from the parent — wrong tool versions, missing  ║
# ║ globals, etc.                                                            ║
# ║                                                                           ║
# ║ See the architecture note in env.zsh for the full startup flow.          ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

source "$ZDOTDIR/env.zsh"
