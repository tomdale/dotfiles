#!/usr/bin/env zsh
# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║ .zshenv - Environment Configuration                                       ║
# ╠═══════════════════════════════════════════════════════════════════════════╣
# ║ Sets environment variables needed by all shell types (login, interactive, ║
# ║ scripts, subshells). This is the first file zsh reads on every invocation.║
# ║                                                                           ║
# ║ Keep this file minimal and fast. Avoid commands with side effects or      ║
# ║ output since this runs for non-interactive scripts too. The actual        ║
# ║ environment setup is in env.zsh for easier maintenance.                   ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Relocate zsh config to XDG-compliant location
export ZDOTDIR="$HOME/.config/zsh"

# Source environment variables and PATH (separated for clarity)
source "$ZDOTDIR/env.zsh"
